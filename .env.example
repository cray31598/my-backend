# Server
PORT=3000

# SQLite (required for persistence when hosted)
# Local: default ./data/app.db (relative to backend folder) is fine.
# Production: set to an absolute path on a persistent volume so create/update/delete survive restarts and deploys.
# Example (Linux host with volume at /data): DATABASE_PATH=/data/app.db
# On Vercel, /tmp is used if unset but data is ephemeral (lost between invocations).
# DATABASE_PATH=/data/app.db
# Set to false to disable WAL mode
# DATABASE_WAL=true
